# GoHighLevel (existing)
GHL_API_KEY=
GHL_LOCATION_ID=

# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Meta Pixel (browser) — same Pixel ID is used for the server CAPI call
NEXT_PUBLIC_META_PIXEL_ID=
META_PIXEL_ID=

# Meta Conversions API (server-only — never expose to the browser)
META_CAPI_ACCESS_TOKEN=

# Optional: set this while testing so events show under "Test Events" in Meta
# Events Manager. Leave unset/empty in production.
META_CAPI_TEST_EVENT_CODE=
